    "dependency-cruiser": "^16.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-jsdoc": "^50.0.0",
    "eslint-plugin-sonarjs": "^3.0.0",
    "eslint-plugin-vue": "^9.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.0",
    "typedoc": "^0.28.0",
    "typedoc-plugin-markdown": "^4.0.0",
    "vue-eslint-parser": "^9.4.0",
    "@types/jquery": "^3.5.32",
