    "@vue/compiler-sfc": "^3.5.33",
    "copy-webpack-plugin": "^11.0.0",
    "cross-env": "^7.0.3",
    "css-loader": "^7.1.2",
    "html-webpack-plugin": "^5.6.3",
    "playwright": "^1.52.0",
