  "scripts": {
    "build": "cross-env NODE_OPTIONS=--max_old_space_size=2048 NODE_ENV=production webpack",
    "dev": "cross-env NODE_OPTIONS=--max_old_space_size=2048 webpack --watch",
    "start": "cross-env NODE_OPTIONS=--max_old_space_size=2048 webpack serve",
    "serve": "cross-env NODE_OPTIONS=--max_old_space_size=2048 webpack serve",
    "typecheck": "tsc --noEmit",
    "test": "jest --config jest.unit.config.js",
    "test:ci": "jest --config jest.coverage.config.js",
    "test:playwright": "playwright test",
    "lint": "eslint src/js",
    "depcruise": "depcruise --config .dependency-cruiser.js src/js",
    "docs": "typedoc --options typedoc.js"
